{
  "name": "deero-management-backend",
  "version": "1.0.0",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev:server": "nodemon --watch src src/index.js",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev --prefix ../frontend\"",
